# ==========================================
# 1. 核心硬件与目标平台配置 (红米 AX6 / IPQ807x)
# ==========================================
CONFIG_MODULES=y
CONFIG_HAVE_DOT_CONFIG=y
CONFIG_HOST_OS_LINUX=y
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq807x=y
CONFIG_TARGET_qualcommax_ipq807x_DEVICE_redmi_ax6-stock=y
CONFIG_HAS_SUBTARGETS=y
CONFIG_HAS_DEVICES=y
CONFIG_TARGET_BOARD="qualcommax"
CONFIG_TARGET_SUBTARGET="ipq807x"
CONFIG_TARGET_PROFILE="DEVICE_redmi_ax6-stock"
CONFIG_TARGET_ARCH_PACKAGES="aarch64_cortex-a53"
CONFIG_DEFAULT_TARGET_OPTIMIZATION="-Os -pipe -mcpu=cortex-a53"
CONFIG_CPU_TYPE="cortex-a53"
CONFIG_LINUX_6_18=y

# ==========================================
# 2. 编译参数与缓存调整 (加速编译与高级选项)
# ==========================================
CONFIG_CCACHE=y                              # 开启编译缓存，大幅加速二次编译
CONFIG_DEVEL=y                               # 开启开发者高级菜单
CONFIG_TARGET_MULTI_PROFILE=y               # 支持多设备配置
CONFIG_TARGET_PER_DEVICE_ROOTFS=y           # 针对特定设备单独打包固件
CONFIG_TARGET_ROOTFS_INITRAMFS=n            # 关闭 initramfs 编译以节省空间
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_SQUASHFS_BLOCK_SIZE=256
CONFIG_TARGET_SQUASHFS_BLOCK_READERS=4
CONFIG_TARGET_SQUASHFS_SMALL_READERS=4
CONFIG_TARGET_UBIFS_FREE_SPACE_FIXUP=y
CONFIG_TARGET_UBIFS_JOURNAL_SIZE=""
CONFIG_JSON_OVERVIEW_IMAGE_INFO=y

# ==========================================
# 3. LuCI 网页端插件调整 (按需增减)
# ==========================================
CONFIG_PACKAGE_luci-app-homeproxy=y         # 【科学插件】集成了强大的 Sing-box 内核
CONFIG_PACKAGE_luci-app-adguardhome=n       # 【关闭】体积过大且吃内存，AX6 上极易死机
CONFIG_PACKAGE_luci-app-autoreboot=y        # 定时重启插件
CONFIG_PACKAGE_luci-app-sqm=y               # SQM 智能队列（有效防爆音、玩游戏降延迟）
CONFIG_PACKAGE_luci-app-ttyd=y              # 网页端终端（直接在浏览器进 SSH）
CONFIG_PACKAGE_luci-app-upnp=y              # UPnP 自动端口转发（提升游戏联机与 NAT 类型）
CONFIG_PACKAGE_luci-app-ramfree=y           # 释放内存小工具
CONFIG_PACKAGE_luci-app-vlmcsd=y            # KMS 局域网激活服务器
CONFIG_PACKAGE_luci-app-eqos=y              # 简易 QoS 控速
CONFIG_PACKAGE_luci-app-arpbind=y           # ARP 绑定（防网络ARP欺骗）
CONFIG_PACKAGE_luci-app-wolplus=y           # 网络唤醒增强版（支持外网唤醒电脑）
CONFIG_PACKAGE_luci-app-cpufreq=y           # CPU 频率与能耗调节面板

# 【关闭无效或冲突的 LuCI 插件】
CONFIG_PACKAGE_luci-app-gecoosac=n          # 集客AC（普通的家用网络不需要）
CONFIG_PACKAGE_luci-app-mini-diskmanager=n  # 磁盘管理（AX6 没有物理 USB 挂硬盘）
CONFIG_PACKAGE_luci-app-partexp=n           # 分区扩容（已刷 U-Boot 扩容，无需此插件）
CONFIG_PACKAGE_luci-app-samba4=n            # 局域网网络共享（硬路由无挂载盘，无需开启）
CONFIG_PACKAGE_luci-app-attendedsysupgrade=n # 自动在线升级（定制固件不建议在线瞎升）
CONFIG_PACKAGE_luci-app-wol=n               # 基础版网络唤醒（已由 wolplus 替代）

# ==========================================
# 4. 剔除无效物理硬件驱动 (SATA/NVMe/音频等)
# ==========================================
CONFIG_AUDIO_SUPPORT=n
CONFIG_PACKAGE_kmod-ata-ahci=n
CONFIG_PACKAGE_kmod-ata-core=n
CONFIG_PACKAGE_kmod-nvme=n
CONFIG_PACKAGE_kmod-sound-core=n
CONFIG_PACKAGE_kmod-usb-audio=n
CONFIG_PACKAGE_libnvme=n
CONFIG_PACKAGE_nvme-cli=n
CONFIG_PACKAGE_smartmontools=n
CONFIG_PACKAGE_smartmontools-drivedb=n

# ==========================================
# 5. 内核虚拟化与手机网络共享驱动 (保留)
# ==========================================
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-ipheth=y        # 支持 iPhone 手机通过数据线共享网络给路由
CONFIG_PACKAGE_kmod-usb-net-rndis=y         # 支持安卓手机通过数据线共享网络给路由
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-net-rtl8152=y       # 支持外接主流的千兆 RTL8152 虚拟网卡
CONFIG_PACKAGE_kmod-bonding=y               # 支持链路聚合
CONFIG_PACKAGE_kmod-veth=y                  # 容器虚拟网卡支持
CONFIG_PACKAGE_kmod-wireguard=y             # WireGuard 轻量化安全网关支持

# ==========================================
# 6. 网络协议与防火墙高级内核支持 (nftables)
# ==========================================
CONFIG_PACKAGE_kmod-tun=y                   # 科学上网必须的虚拟网卡驱动
CONFIG_PACKAGE_kmod-fuse=y                  # 虚拟文件系统支持
CONFIG_PACKAGE_kmod-fs-btrfs=y
CONFIG_PACKAGE_kmod-fs-ksmbd=y
CONFIG_PACKAGE_kmod-dummy=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-inet-mptcp-diag=y
CONFIG_PACKAGE_kmod-mtd-rw=y
CONFIG_PACKAGE_kmod-netlink-diag=y
CONFIG_PACKAGE_kmod-nf-nat6=y
CONFIG_PACKAGE_kmod-nft-arp=y
CONFIG_PACKAGE_kmod-nft-bridge=y
CONFIG_PACKAGE_kmod-nft-connlimit=y
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-dup-inet=y
CONFIG_PACKAGE_kmod-nft-fib=y
CONFIG_PACKAGE_kmod-nft-fullcone=y          # NAT1 满锥型 NAT 硬件加速支持
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-netdev=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nft-queue=y
CONFIG_PACKAGE_kmod-nft-socket=y
CONFIG_PACKAGE_kmod-nft-tproxy=y            # 科学上网透明代理的核心驱动
CONFIG_PACKAGE_kmod-nft-xfrm=y
CONFIG_PACKAGE_kmod-ovpn-backports=y

# ==========================================
# 7. 实用系统小工具与核心依赖库
# ==========================================
CONFIG_PACKAGE_autocore=y                   # 首页显示 CPU 频率、温度
CONFIG_PACKAGE_automount=y                  # 挂载助手
CONFIG_PACKAGE_blkid=y                      # 查看设备 UUID 
CONFIG_PACKAGE_cfdisk=y                     # 磁盘分区工具
CONFIG_PACKAGE_cgdisk=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_gdisk=y
CONFIG_PACKAGE_sfdisk=y
CONFIG_PACKAGE_sgdisk=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_coremark=y                   # 跑分测速小工具
CONFIG_PACKAGE_cpufreq=y                    # CPU 调频组件
CONFIG_PACKAGE_curl=y                       # 网络请求、如下载脚本
CONFIG_PACKAGE_dmesg=y                      # 调试与查看内核日志
CONFIG_PACKAGE_htop=y                       # 炫酷的系统进程、内存、CPU 查看器
CONFIG_PACKAGE_iperf3=y                     # 局域网内网打流打满内网测速工具
CONFIG_PACKAGE_ip-full=y                     # 完整的 IP 命令集
CONFIG_PACKAGE_libimobiledevice=y           # 苹果设备握手依赖
CONFIG_PACKAGE_usbmuxd=y
CONFIG_PACKAGE_usb-modeswitch=y             # USB 模式切换（用于网卡形态切换）
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_xz-utils=y
CONFIG_PACKAGE_exfat-fsck=y                 # exFAT 文件系统修复工具
CONFIG_PACKAGE_exfat-mkfs=y                 # exFAT 格式化工具

# ==========================================
# 8. LuCI 基础框架与基本依赖
# ==========================================
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-base=y
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_PACKAGE_luci-lua-runtime=y
CONFIG_PACKAGE_luci-proto-relay=y
CONFIG_PACKAGE_proto-bonding=y
CONFIG_PACKAGE_mmc-utils=y
CONFIG_PACKAGE_nand-utils=y
CONFIG_PACKAGE_openssh-keygen=y
CONFIG_PACKAGE_openssh-sftp-server=y        # 支持通过 SFTP (如 FileZilla) 传输文件
CONFIG_PACKAGE_openssl-util=y

# ==========================================
# 9. 高通平台默认自带的 NSS 加速与 Wi-Fi 驱动
# ==========================================
CONFIG_DEFAULT_ath11k-firmware-ipq8074-ddwrt=y
CONFIG_DEFAULT_ipq-wifi-redmi_ax6=y
CONFIG_DEFAULT_kmod-ath11k=y
CONFIG_DEFAULT_kmod-ath11k-ahb=y
CONFIG_DEFAULT_kmod-ath11k-pci=y
CONFIG_DEFAULT_kmod-dsa=y
CONFIG_DEFAULT_kmod-dsa-qca8k=y
CONFIG_DEFAULT_kmod-fs-ext4=y
CONFIG_DEFAULT_kmod-fs-f2fs=y
CONFIG_DEFAULT_kmod-gpio-button-hotplug=y
CONFIG_DEFAULT_kmod-leds-gpio=y
CONFIG_DEFAULT_kmod-leds-pwm=y
CONFIG_DEFAULT_kmod-phy-aquantia=y
CONFIG_DEFAULT_kmod-phy-qca83xx=y
CONFIG_PACKAGE_kmod-qca-wifi=y
CONFIG_DEFAULT_kmod-qca-nss-crypto=y
CONFIG_DEFAULT_kmod-qca-nss-dp=y
CONFIG_DEFAULT_kmod-qca-nss-drv=y
CONFIG_DEFAULT_kmod-qca-nss-drv-bridge-mgr=y
CONFIG_DEFAULT_kmod-qca-nss-drv-eogremgr=y
CONFIG_DEFAULT_kmod-qca-nss-drv-gre=y
CONFIG_DEFAULT_kmod-qca-nss-drv-igs=y
CONFIG_DEFAULT_kmod-qca-nss-drv-l2tpv2=y
CONFIG_DEFAULT_kmod-qca-nss-drv-lag-mgr=y
CONFIG_DEFAULT_kmod-qca-nss-drv-map-t=y
CONFIG_DEFAULT_kmod-qca-nss-drv-match=y
CONFIG_DEFAULT_kmod-qca-nss-drv-mirror=y
CONFIG_DEFAULT_kmod-qca-nss-drv-netlink=y
CONFIG_DEFAULT_kmod-qca-nss-drv-pppoe=y
CONFIG_DEFAULT_kmod-qca-nss-drv-pptp=y
CONFIG_DEFAULT_kmod-qca-nss-drv-qdisc=y
CONFIG_DEFAULT_kmod-qca-nss-drv-tun6rd=y
CONFIG_DEFAULT_kmod-qca-nss-drv-tunipip6=y
CONFIG_DEFAULT_kmod-qca-nss-drv-vlan-mgr=y
CONFIG_DEFAULT_kmod-qca-nss-drv-vxlanmgr=y
CONFIG_DEFAULT_kmod-qca-nss-ecm=y
CONFIG_DEFAULT_libustream-openssl=y
CONFIG_DEFAULT_wpad-openssl=y

